# ──────────────────────────────────────────────
# JS Playground — Environment Variables Example
# ──────────────────────────────────────────────
# Copy this file to artifacts/api-server/.env
# and fill in your values before starting the server.
#
#   cp .env.example artifacts/api-server/.env
# ──────────────────────────────────────────────

# PostgreSQL connection string
# Format: postgresql://<user>:<password>@<host>:<port>/<database>
# Examples:
#   Local default:  postgresql://postgres:postgres@localhost:5432/jsplayground
#   With password:  postgresql://myuser:mypassword@localhost:5432/jsplayground
#   Neon (cloud):   postgresql://user:pass@ep-xxx.us-east-1.aws.neon.tech/jsplayground?sslmode=require
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/jsplayground

# Port the API server listens on
PORT=8080

# Secret used to sign sessions — use any long random string
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-this-to-a-long-random-secret-string

# Node environment (development | production)
NODE_ENV=development
